---
const { src, alt } = Astro.props;
interface Props {
  src: string;
  alt: string;
}
---

<img
  id="img"
  class="animate__animated animate__fadeIn"
  src={src}
  alt={alt}
/>

<style lang="scss">
  #img {
    margin-top: 20px;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    // back
  }
</style>

<script>
  const image = document.querySelector("#img") as HTMLImageElement;

  const handleLoad = () => {
    if (image.complete) {
      image.style.filter = "blur(0px)";
    }
  };

  handleLoad();
</script>
