---
const { src, alt } = Astro.props;
interface Props {
  src: string;
  alt: string;
}
---

<div class="image--wrapper">
  <img id="img" class="animate__animated animate__fadeIn" src={src} alt={alt} />
</div>

<style lang="scss">
  @use "../../styles/utils/" as u;
  .image--wrapper {
    width: 100%;
    aspect-ratio: 4 / 3;
    margin-top: 20px;
    border-radius: u.rem(8);
    border: solid 1px var(--color-border-code);
    background: radial-gradient(circle, var(--color-body-bg) 0%, var(--color-fore-bg) 100%);

    #img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: inherit;
    }
  }
</style>

<script>
  const image = document.querySelector("#img") as HTMLImageElement;

  const handleLoad = () => {
    if (image.complete) {
      image.style.filter = "blur(0px)";
    }
  };

  handleLoad();
</script>
