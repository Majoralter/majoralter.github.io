---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;
---

<div class="toc__wrapper">
    <p>On this page</p>
  <div class="headings">
    <ul role="list">
      {
        headings.map((heading) => (
          <li>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style lang="scss">
  @use "../../styles/utils/" as u;

  .toc__wrapper {
    width: fit-content;
    height: fit-content;
    position: fixed;
    right: u.rem(100);
    @include u.display-flex(column, flex-start, flex-start, .5em, nowrap);

    p {
        font-style: italic;
        font-weight: 500;
    }

    .headings {
      ul {
        @include u.display-flex(column, flex-start, flex-start, .25em, nowrap);

        li {
            a {
                text-decoration: none;
                font-size: u.rem(13);

                &:hover {
                    color: #ff4500;
                }
            }
        }
      }
    }

    @media (max-width: 1306px) {
        display: none;
    }
  }
</style>
